# Required: encryption key for the API key vault (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
MASTER_KEY=your-fernet-master-key-here

# Optional: default NVIDIA API key used on first startup if vault is empty
# It is recommended to add keys through the UI instead.
NVIDIA_API_KEY=nvapi-your-key-here

# Database URL (defaults to SQLite in data/)
DATABASE_URL=sqlite:///data/clinicalsafe_nim.db

# NIM configuration
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_DEFAULT_MODEL=meta/llama-3.3-70b-instruct
NIM_TIMEOUT_SECONDS=60

# Application
LOG_LEVEL=INFO
